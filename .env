# ==================== 1.全局安全必改（所有环境必须替换，复制随机字符） ====================
# 加密盐，32位随机字符，不要使用默认salt
COOKIE_SIGNING_SALT=7sdf92jhg10387xvbnzqwerty456129
# Postgres数据库密码，自定义强密码
PENTAGI_POSTGRES_PASSWORD=PentagiQwen@2026#DB
# Neo4j知识库密码（Graphiti关闭也建议修改）
NEO4J_PASSWORD=Neo4jSafe@6688
# Langfuse加密密钥，64位随机字符
LANGFUSE_ENCRYPTION_KEY=4567890abcdef1234567890qwertyuiopzxcvbnm9876543210asdfghjklzxcvbnm

# ==================== 2.通义千问QWEN核心配置（仅此处填入你的DashScope密钥） ====================
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QWEN_SERVER_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_PROVIDER=qwen

# 其他所有云端大模型全部置空（禁用OpenAI/DeepSeek/GLM/Kimi/Gemini等）
OPEN_AI_KEY=
OPEN_AI_SERVER_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=
ANTHROPIC_SERVER_URL=https://api.anthropic.com/v1

GEMINI_API_KEY=
GEMINI_SERVER_URL=https://generativelanguage.googleapis.com

DEEPSEEK_API_KEY=
DEEPSEEK_SERVER_URL=https://api.deepseek.com
DEEPSEEK_PROVIDER=

GLM_API_KEY=
GLM_SERVER_URL=https://api.z.ai/api/paas/v4
GLM_PROVIDER=

KIMI_API_KEY=
KIMI_SERVER_URL=https://api.moonshot.ai/v1
KIMI_PROVIDER=

# ==================== 3.Ollama全部禁用（场景2不需要本地Ollama，全部留空） ====================
OLLAMA_SERVER_URL=
OLLAMA_SERVER_API_KEY=
OLLAMA_SERVER_MODEL=
OLLAMA_SERVER_CONFIG_PATH=
OLLAMA_SERVER_PULL_MODELS_TIMEOUT=
OLLAMA_SERVER_PULL_MODELS_ENABLED=
OLLAMA_SERVER_LOAD_MODELS_ENABLED=

# ==================== 4.向量嵌入Embedding（复用通义千问DashScope接口） ====================
EMBEDDING_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx # 和上面QWEN_API_KEY保持一致
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_PROVIDER=openai
EMBEDDING_BATCH_SIZE=10
EMBEDDING_MAX_TEXT_BYTES=20000
EMBEDDING_STRIP_NEW_LINES=true

# ==================== 5.摘要/助手Agent默认参数（无需修改） ====================
SUMMARIZER_PRESERVE_LAST=5
SUMMARIZER_USE_QA=true
SUMMARIZER_SUM_MSG_HUMAN_IN_QA=true
SUMMARIZER_LAST_SEC_BYTES=10000
SUMMARIZER_MAX_BP_BYTES=50000
SUMMARIZER_MAX_QA_SECTIONS=10
SUMMARIZER_MAX_QA_BYTES=30000
SUMMARIZER_KEEP_QA_SECTIONS=true

ASSISTANT_USE_AGENTS=true
ASSISTANT_SUMMARIZER_PRESERVE_LAST=5
ASSISTANT_SUMMARIZER_LAST_SEC_BYTES=10000
ASSISTANT_SUMMARIZER_MAX_BP_BYTES=50000
ASSISTANT_SUMMARIZER_MAX_QA_SECTIONS=10
ASSISTANT_SUMMARIZER_MAX_QA_BYTES=30000
ASSISTANT_SUMMARIZER_KEEP_QA_SECTIONS=true

# ==================== 6.Agent执行限制（防死循环、优化渗透任务） ====================
EXECUTION_MONITOR_ENABLED=true
EXECUTION_MONITOR_SAME_TOOL_LIMIT=10
EXECUTION_MONITOR_TOTAL_TOOL_LIMIT=200

MAX_GENERAL_AGENT_TOOL_CALLS=120
MAX_LIMITED_AGENT_TOOL_CALLS=60

AGENT_PLANNING_STEP_ENABLED=true

# ==================== 7.网络代理（国内阿里云接口无需代理，留空） ====================
PROXY_URL=
EXTERNAL_SSL_CA_PATH=
EXTERNAL_SSL_INSECURE=false

# ==================== 8.超时时间（适配国内接口延迟） ====================
HTTP_CLIENT_TIMEOUT=600
TERMINAL_TOOL_TIMEOUT=10800

# ==================== 9.爬虫配置（默认无需修改） ====================
SCRAPER_PUBLIC_URL=
SCRAPER_PRIVATE_URL=https://someuser:somepass@scraper/
LOCAL_SCRAPER_USERNAME=someuser
LOCAL_SCRAPER_PASSWORD=somepass
LOCAL_SCRAPER_MAX_CONCURRENT_SESSIONS=10

# ==================== 10.面板访问地址（二选一） ====================
## 选项A：仅本机访问（个人电脑本地测试）
PUBLIC_URL=https://localhost:8443
CORS_ORIGINS=https://localhost:8443

## 选项B：局域网/服务器公网访问（替换为你的服务器IP，注释上面A）
# PUBLIC_URL=https://192.168.1.105:8443
# CORS_ORIGINS=https://192.168.1.105:8443

COOKIE_SIGNING_SALT=7sdf92jhg10387xvbnzqwerty456129

