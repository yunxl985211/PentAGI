# ===================== 本地Ollama核心配置（离线关键） =====================
OLLAMA_SERVER_URL=http://host.docker.internal:11434
OLLAMA_SERVER_API_KEY=
OLLAMA_SERVER_MODEL=llama3.1:8b
OLLAMA_SERVER_CONFIG_PATH=
OLLAMA_SERVER_PULL_MODELS_TIMEOUT=600
OLLAMA_SERVER_PULL_MODELS_ENABLED=true
OLLAMA_SERVER_LOAD_MODELS_ENABLED=true

# ===================== Ollama向量嵌入Embedding =====================
EMBEDDING_URL=http://host.docker.internal:11434/v1
EMBEDDING_KEY=
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_PROVIDER=ollama
EMBEDDING_BATCH_SIZE=10
EMBEDDING_MAX_TEXT_BYTES=20000
EMBEDDING_STRIP_NEW_LINES=true

## 文本摘要优化参数
SUMMARIZER_PRESERVE_LAST=5
SUMMARIZER_USE_QA=true
SUMMARIZER_SUM_MSG_HUMAN_IN_QA=true
SUMMARIZER_LAST_SEC_BYTES=10000
SUMMARIZER_MAX_BP_BYTES=50000
SUMMARIZER_MAX_QA_SECTIONS=10
SUMMARIZER_MAX_QA_BYTES=30000
SUMMARIZER_KEEP_QA_SECTIONS=true

ASSISTANT_USE_AGENTS=true
ASSISTANT_SUMMARIZER_PRESERVE_LAST=5
ASSISTANT_SUMMARIZER_LAST_SEC_BYTES=10000
ASSISTANT_SUMMARIZER_MAX_BP_BYTES=50000
ASSISTANT_SUMMARIZER_MAX_QA_SECTIONS=10
ASSISTANT_SUMMARIZER_MAX_QA_BYTES=30000
ASSISTANT_SUMMARIZER_KEEP_QA_SECTIONS=true

## Agent防卡死限制
EXECUTION_MONITOR_ENABLED=true
EXECUTION_MONITOR_SAME_TOOL_LIMIT=10
EXECUTION_MONITOR_TOTAL_TOOL_LIMIT=200
MAX_GENERAL_AGENT_TOOL_CALLS=120
MAX_LIMITED_AGENT_TOOL_CALLS=60
AGENT_PLANNING_STEP_ENABLED=true

## 网络代理（离线不需要，留空）
PROXY_URL=
EXTERNAL_SSL_CA_PATH=
EXTERNAL_SSL_INSECURE=false

## 超时配置
HTTP_CLIENT_TIMEOUT=600
TERMINAL_TOOL_TIMEOUT=10800

